{
  "manifest_version": 3,
  "name": "Tailor – Recruiter Outreach",
  "version": "0.1.0",
  "description": "Turn any LinkedIn profile into a sharp, personal outreach opener in one click.",
  "permissions": ["sidePanel", "activeTab", "scripting", "storage"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Tailor – Open side panel"
  }
}
